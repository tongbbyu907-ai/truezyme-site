# Supabase — Project Settings > API에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin login (단일 관리자)
# ADMIN_PASSWORD_HASH는 bcrypt 해시값. 아래 명령으로 생성:
#   node -e "console.log(require('bcryptjs').hashSync('your_password_here', 10))"
ADMIN_EMAIL=admin@truezyme.local
ADMIN_PASSWORD_HASH=$2a$10$REPLACE_WITH_YOUR_HASH

# Session JWT secret (랜덤 문자열, 최소 32자)
# 생성: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_random_64_char_hex_string
